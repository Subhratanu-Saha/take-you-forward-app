generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model customer {
  customerid        String        @id @db.VarChar(20)
  firstname         String        @db.VarChar(50)
  lastname          String?       @db.VarChar(50)
  emailadd          String        @unique(map: "customer_emailaddr_key") @db.VarChar(100)
  contactnum        String?       @db.VarChar(20)
  addressline1      String        @db.VarChar(100)
  addressline2      String?       @db.VarChar(100)
  city              String        @db.VarChar(30)
  pincode           String        @db.VarChar(10)
  gender            String?       @db.VarChar(1)
  dob               DateTime      @db.Date
  isloyalty         Boolean?
  sysenrollmentdt   DateTime?     @db.Timestamp(6)
  syslastmodifieddt DateTime?     @db.Timestamp(6)
  interaction       interaction[]
  orderheader       orderheader[]
  subscriber        subscriber[]
}

model interaction {
  customerid        String?   @db.VarChar(20)
  interactionid     String    @id @db.VarChar(20)
  interactionvalue  String    @db.VarChar(40)
  interactionmode   String    @db.VarChar(20)
  interactiontype   String    @db.VarChar(40)
  syslastmodifieddt DateTime? @db.Timestamp(6)
  customer          customer? @relation(fields: [customerid], references: [customerid], onDelete: NoAction, onUpdate: NoAction)
}

model orderheader {
  orderid           String           @id @db.VarChar(20)
  customerid        String?          @db.VarChar(20)
  totalamount       Decimal          @db.Decimal(10, 2)
  taxamount         Decimal?         @db.Decimal(10, 2)
  channel           String?          @db.VarChar(10)
  payment           String           @db.VarChar(10)
  discount          Decimal?         @db.Decimal(10, 2)
  isloyalty         Boolean?
  syslastmodifieddt DateTime?        @db.Timestamp(6)
  customer          customer?        @relation(fields: [customerid], references: [customerid], onDelete: NoAction, onUpdate: NoAction)
  orderlineitems    orderlineitems[]
}

model orderlineitems {
  orderitemid String       @id @db.VarChar(50)
  orderid     String?      @db.VarChar(50)
  skuid       String       @db.VarChar(20)
  skuitem     String       @db.VarChar(200)
  skuquantity String       @db.VarChar(3)
  skuprice    Decimal      @db.Decimal(10, 2)
  orderheader orderheader? @relation(fields: [orderid], references: [orderid], onDelete: NoAction, onUpdate: NoAction)
}

model subscriber {
  customerid        String?   @db.VarChar(20)
  subscriberid      String    @id @db.VarChar(20)
  issubscribe       Boolean
  emailpermstatus   Boolean
  smspermstatus     Boolean
  syslastmodifieddt DateTime? @db.Timestamp(6)
  customer          customer? @relation(fields: [customerid], references: [customerid], onDelete: NoAction, onUpdate: NoAction)
}
